# Database Configuration - Choose ONE of the options below
# Option 1: Individual Variables (Recommended for Aiven/Render)
# DB_HOST=mysql-355200ee-iisdenrdatabase.g.aivencloud.com
# DB_PORT=17790
# DB_USER=avnadmin
# DB_PASSWORD=your-db-password
# DB_NAME=defaultdb
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# Option 2: Base64-encoded SSL CA (optional)
# DB_SSL_CA_BASE64=
# Option 3: Raw SSL CA certificate (optional, multi-line)
# DB_SSL_CA=-----BEGIN CERTIFICATE-----
# ... your certificate here ...
# -----END CERTIFICATE-----

# Option 2: Connection String (Backward Compatible)
# DATABASE_CLIENT=mysql2
# DATABASE_URL=mysql://user:password@host:port/dbname

# JWT Configuration (REQUIRED FOR PRODUCTION)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars

# Server Configuration
PORT=3000
BIND_HOST=0.0.0.0
NODE_ENV=development
TRUST_PROXY=false

# CORS Configuration
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# File Upload Configuration
MAX_UPLOAD_BYTES=10485760
UPLOAD_MIME_ALLOWLIST=application/pdf,image/png,image/jpeg,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation

# Backup Configuration
ENABLE_ADMIN_RESTORE=false
BACKUP_INCLUDE_UPLOADS=false
BACKUP_KEEP=10

# Email Configuration with Resend
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL="DENR Scheduler" <no-reply@denr.gov.ph>

# Timezone Configuration
APP_TIMEZONE=

# Data Storage Backend
DATA_BACKEND=db
DATA_DIR=./data

# Table prefix for database tables
DB_TABLE_PREFIX=

# Stream Token TTL in ms
STREAM_TOKEN_TTL_MS=120000
