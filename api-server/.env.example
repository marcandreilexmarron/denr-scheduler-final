# Server
NODE_ENV=development
PORT=3000
BIND_HOST=0.0.0.0
TRUST_PROXY=false
APP_TIMEZONE=Asia/Manila

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
DATA_BACKEND=db
DATA_DIR=./data

# Database
DATABASE_CLIENT=mysql2
DATABASE_URL=mysql://USERNAME:PASSWORD@HOST:3306/defaultdb
DB_TABLE_PREFIX=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_CA_CERT_BASE64=

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@example.com

# Uploads
MAX_UPLOAD_BYTES=10485760
UPLOAD_MIME_ALLOWLIST=application/pdf,image/png,image/jpeg,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation

# Admin / backup options
ENABLE_ADMIN_RESTORE=false
STREAM_TOKEN_TTL_MS=120000
BACKUP_INCLUDE_UPLOADS=false
BACKUP_KEEP=30
